{
  "name": "report-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint-check": "node scripts/lint-check.mjs",
    "sql-syntax": "node scripts/sql-syntax-check.mjs",
    "bundle-smoke": "node scripts/bundle-smoke.mjs",
    "migrate-check": "node scripts/migration-idempotency-check.mjs",
    "layer1": "npm run lint-check && npm run sql-syntax && npm run bundle-smoke",
    "test:handshake": "node scripts/test-mcp-handshake.mjs",
    "test:output-schemas": "node scripts/test-output-schemas.mjs",
    "test:annotations": "node scripts/test-tool-annotations.mjs",
    "test:pagination": "node scripts/test-pagination.mjs",
    "test:jwt": "node scripts/test-jwt-verify.mjs",
    "test:cross-tenant": "node scripts/test-cross-tenant-isolation.mjs",
    "test:tool-uniqueness": "node scripts/test-tool-name-uniqueness.mjs",
    "test:desc-length": "node scripts/test-description-length.mjs",
    "build:tools-snapshot": "node scripts/build-tools-snapshot.mjs",
    "test:evals": "npm run build:tools-snapshot && node scripts/eval-runner.mjs",
    "test:evals:update-baseline": "npm run build:tools-snapshot && node scripts/eval-runner.mjs --update-baseline",
    "layer2": "npm run test:output-schemas && npm run test:annotations && npm run test:pagination && npm run test:handshake && npm run test:jwt && npm run test:cross-tenant",
    "layer3": "npm run test:evals",
    "test:all": "npm run layer1 && npm run layer2 && npm run layer3"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@netlify/blobs": "^10.7.4",
    "@netlify/database": "^1.0.0",
    "@sparticuz/chromium": "^143.0.4",
    "node-html-parser": "^7.1.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "puppeteer-core": "^24.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^24.1.3",
    "netlify-cli": "^26.0.2",
    "vite": "^5.4.8",
    "vitest": "^1.6.1"
  }
}
